# ============================================================
# BioChem Career Automation System — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to GitHub
# ============================================================

# ── LLM Backend (pick ONE) ───────────────────────────────────
# Option A: Groq (free cloud — recommended for GitHub Actions)
GROQ_API_KEY=gsk_...          # Free: console.groq.com (14,400 req/day)
LLM_BACKEND=groq              # groq | ollama | together
GROQ_MODEL=llama3-8b-8192

# Option B: Ollama (local only — free, runs on your machine)
# LLM_BACKEND=ollama
# OLLAMA_MODEL=mistral         # mistral | llama3 | gemma2

# Option C: Together AI (free credits on signup)
# TOGETHER_API_KEY=...
# LLM_BACKEND=together

# ── Gmail (for application email sending) ────────────────────
GMAIL_ADDRESS=your.email@gmail.com
# App Password — NOT your real password
# Get at: myaccount.google.com/apppasswords
GMAIL_APP_PASS=xxxx xxxx xxxx xxxx

# ── Google Sheets CRM (optional but recommended) ─────────────
# Name of your Google Sheet (create a blank one)
GOOGLE_SHEET_NAME=BioChem Job Tracker
# Path to service account JSON key file
# Get from: console.cloud.google.com → Service Accounts → Keys
# In GitHub Actions: paste entire JSON content as GOOGLE_CREDENTIALS_JSON secret
GOOGLE_CREDENTIALS_FILE=google_credentials.json

# ── Settings ─────────────────────────────────────────────────
MATCH_SCORE_THRESHOLD=60      # 0-100: minimum score to generate CV
MAX_JOBS_PER_RUN=100          # Max jobs to scrape per run
APPLICATIONS_PER_DAY=50       # Max applications per day
